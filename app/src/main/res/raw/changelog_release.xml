<?xml version="1.0" encoding="utf-8"?>
<changelog bulletedList="true">
    <changelogversion versionName="1.0.2" changeDate="Apr 25,2026">
        <changelogtext>[b]Bug Fixes[/b]</changelogtext>
        <changelogtext>Fix overscroll stretch causing items to become untappable on the More screen</changelogtext>
        <changelogtext>Fix bottom navigation bar clipping content on the More screen</changelogtext>
        <changelogtext>Add debug build variant support for Google Services</changelogtext>
        <changelogtext>[b]Improvements[/b]</changelogtext>
        <changelogtext>Improved touch target accuracy after scroll boundary interactions</changelogtext>
        <changelogtext>Proper contentPadding handling for ScrollbarLazyColumn</changelogtext>
    </changelogversion>
    <changelogversion versionName="1.0.1" changeDate="Apr 24,2026">
        <changelogtext>[b]UI Enhancements[/b]</changelogtext>
        <changelogtext>Custom floating island navigation bar with bouncy animations</changelogtext>
        <changelogtext>Enhanced library grid items with deeper gradients and refined typography</changelogtext>
        <changelogtext>Adjusted badge styling for a premium aesthetic</changelogtext>
        <changelogtext>[b]Build[/b]</changelogtext>
        <changelogtext>Enable debug signing configuration for release build variants</changelogtext>
        <changelogtext>Fix navigation bar height (80dp) Android display issue</changelogtext>
    </changelogversion>
    <changelogversion versionName="1.0.0" changeDate="Apr 24,2026">
        <changelogtext>[b]Welcome to KOMA (コマ)![/b]</changelogtext>
        <changelogtext>A free, open-source manga reader based on Mihon and TachiyomiSY</changelogtext>
        <changelogtext>[b]Rebranding[/b]</changelogtext>
        <changelogtext>New KOMA app identity with custom splash screen and logo</changelogtext>
        <changelogtext>Midnight Deep color theme implementation</changelogtext>
        <changelogtext>Custom app icons and branding assets</changelogtext>
        <changelogtext>[b]Features[/b]</changelogtext>
        <changelogtext>Full Mihon/TachiyomiSY feature set included</changelogtext>
        <changelogtext>Cross-device sync support</changelogtext>
        <changelogtext>Extension management and source browsing</changelogtext>
        <changelogtext>Advanced library search and filtering</changelogtext>
        <changelogtext>Every chapter. Everywhere.</changelogtext>
    </changelogversion>
</changelog>
